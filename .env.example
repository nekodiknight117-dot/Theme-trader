# =============================================================
# Theme-Trader Environment Variables
# =============================================================
# SETUP: Copy this file to .env in the PROJECT ROOT directory
#        (same folder as this file) and fill in your keys.
#
#   cp .env.example .env        (Mac/Linux)
#   copy .env.example .env      (Windows PowerShell)
# =============================================================

# ----------------------------------------------------------
# Alpaca API  (Real-time market data & WebSocket stream)
# Get keys: https://app.alpaca.markets/paper/dashboard/overview
# ----------------------------------------------------------
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here

# ----------------------------------------------------------
# Tavily API  (Qualitative stock research & news)
# Get key: https://app.tavily.com/
# ----------------------------------------------------------
TAVILY_API_KEY=your_tavily_api_key_here

# ----------------------------------------------------------
# Featherless LLM  (Required — serverless AI inference)
# Get key: https://featherless.ai -> Dashboard -> API Keys
# Model: google/gemma-4-31B-it
# ----------------------------------------------------------
FEATHERLESS_API_KEY=your_featherless_api_key_here

# ----------------------------------------------------------
# Database  (SQLite for development)
# ----------------------------------------------------------
DATABASE_URL=sqlite:///./theme_trader.db
