# API Keys for Theme-Trader Backend

# Alpaca API (Market Data & WebSockets)
# Get keys from https://app.alpaca.markets/paper/dashboard/overview
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here

# Tavily API (Qualitative Stock Research & News)
# Get key from https://app.tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# Local LLM Integration (LM Studio)
# Default LM Studio local server URL
OPENAI_BASE_URL=http://146.245.228.220:1234/v1
# Fake API key required by the openai python client, even for local servers
OPENAI_API_KEY=lm-studio

# Alternative Serverless LLM (Featherless)
# If using Featherless, change OPENAI_BASE_URL to their endpoint (e.g., https://api.featherless.ai/v1)
# and provide your API key below.
FEATHERLESS_API_KEY=your_featherless_api_key_here

# Database
# For Hackathon: sqlite:///./theme_trader.db
# For Production (PostgreSQL): postgresql://user:password@localhost/dbname
DATABASE_URL=sqlite:///./theme_trader.db
